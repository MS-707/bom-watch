# BOM Watch — Vendor API Configuration
# Copy to .env.local and fill in your values

# DigiKey API v4 (free tier — register at https://developer.digikey.com)
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_SANDBOX=true

# Mouser Search API (free — register at https://www.mouser.com/api-hub/)
MOUSER_API_KEY=

# Grainger API (requires business account)
GRAINGER_API_KEY=
GRAINGER_ACCOUNT_ID=

# OEM Secrets (39+ distributor pricing — https://oemsecretsapi.com)
OEMSECRETS_API_KEY=

# Anthropic Claude AI (insights & analysis)
ANTHROPIC_API_KEY=

# Arena PLM
ARENA_API_KEY=
ARENA_WEBHOOK_SECRET=

# Slack Notifications
SLACK_WEBHOOK_URL=
